// ============================================
// DEAN'S SHIPPING LTD - DATABASE SCHEMA
// ============================================
// PostgreSQL via Supabase + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  USER
  AGENT
  ADMIN
}

enum PriceCategory {
  DRY_BOX
  FROZEN_BOX
  COOLER_BOX
  ENVELOPE
  CONTAINER
  LUGGAGE
  PALLET
  VEHICLE
  BUNDLE
  PASSENGER
}

enum ContainerType {
  DRY
  FROZEN
  COOLER
}

// Updated: Now includes all service types from the UI
enum CargoServiceType {
  CONTAINER
  PALLET
  LUGGAGE
  BOX
  ENVELOPE
  BUNDLE
  OTHER
}

// Box sub-types (when service = BOX)
enum BoxSubType {
  DRY
  FROZEN
  COOLER
}

enum CargoSizeCategory {
  SMALL
  MEDIUM
  LARGE
  FRAGILE
  HAZARDOUS
  LIVE
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum EquipmentType {
  FORKLIFT
  MULE
  CHASSIS
  CONTAINER
  FLAT_RACK
}

enum EquipmentStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum VehicleStatus {
  PENDING
  IN_DOCK
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum VoyageStatus {
  SCHEDULED
  BOARDING
  DEPARTED
  ARRIVED
  COMPLETED
  CANCELLED
}

enum ManifestItemStatus {
  PENDING
  LOADED
  UNLOADED
  DELIVERED
}

enum ReminderFrequency {
  DAILY
  EVERY_2_DAYS
  EVERY_5_DAYS
  EVERY_7_DAYS
}

// Damage types for deficiency tracking
enum DamageType {
  BROKEN
  IMPROPERLY_PACKAGED
  ITEM_MISSING
  BENT
  SCRATCHED
  DAMAGED
  WET
  TORN
  OTHER
}

// Damage location options
enum DamageLocationEnum {
  LEFT_UPPER_CORNER
  RIGHT_UPPER_CORNER
  LEFT_LOWER_CORNER
  RIGHT_LOWER_CORNER
  TOP
  BOTTOM
  LEFT
  RIGHT
  LEFT_CENTER
  RIGHT_CENTER
  FRONT
  BACK
  MULTIPLE
}

// Envelope types
enum EnvelopeType {
  SMALL_BOX
  ENVELOPE
  PARCEL
}

// Item location for bundles
enum ItemLocationType {
  PALLET
  CONTAINER
  DECK
}

// ============================================
// USER & AUTH MODELS
// ============================================

model User {
  id           String   @id @default(cuid())
  firebaseUid  String?  @unique
  firstName    String
  lastName     String
  email        String   @unique
  countryCode  String   @default("+1")
  mobileNumber String   @unique
  role         Role     @default(USER)
  password     String?
  designation  String?
  isActive     Boolean  @default(true)
  avatarUrl    String?

  // Agent-specific fields
  agentCode    String?   @unique
  agentLocation String?  // Primary location for agent

  // Relations
  cargoBookings       CargoBooking[]
  passengerBookings   PassengerBooking[]
  invoices            Invoice[]
  notifications       Notification[]
  incidentReports     IncidentReport[]
  auditLogs           AuditLog[]
  equipmentAssigned   EquipmentAssignment[] @relation("AssignedTo")
  equipmentAssignedBy EquipmentAssignment[] @relation("AssignedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([mobileNumber])
  @@index([email])
}

// ============================================
// LOCATIONS
// ============================================

model Location {
  id   String @id @default(cuid())
  code String @unique // NAS, GTC, MHA, GGC_BB, MOW_HPT, NA
  name String // Nassau, Green Turtle Cay, Marsh Harbour

  // Relations
  pricesFrom  Price[]     @relation("PriceFrom")
  pricesTo    Price[]     @relation("PriceTo")
  equipmentAt Equipment[]
  
  // Voyage relations
  voyagesFrom Voyage[] @relation("VoyageFrom")
  voyagesTo   Voyage[] @relation("VoyageTo")
  voyageStops VoyageStop[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// PRICING
// ============================================

model Price {
  id       String        @id @default(cuid())
  category PriceCategory
  size     String // "Small", "Medium", "Large", "05 ft", "20 ft", "40 ft", etc.
  type     ContainerType? // Only for containers
  value    Float

  fromId String
  from   Location @relation("PriceFrom", fields: [fromId], references: [id])
  toId   String
  to     Location @relation("PriceTo", fields: [toId], references: [id])

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([fromId, toId])
  @@unique([category, size, type, fromId, toId])
}

// ============================================
// VOYAGES
// ============================================

model Voyage {
  id          String       @id @default(cuid())
  voyageNo    Int          @unique // 208, 207, etc.
  shipName    String       // "SHIP_A" or "SHIP_B"
  date        DateTime
  status      VoyageStatus @default(SCHEDULED)

  // Route
  fromId String
  from   Location @relation("VoyageFrom", fields: [fromId], references: [id])
  toId   String
  to     Location @relation("VoyageTo", fields: [toId], references: [id])

  // Capacity tracking
  maxCargoCapacity   Int?    // Maximum cargo units
  maxPassengers      Int?    // Maximum passengers
  currentCargoCount  Int     @default(0)
  currentPassengers  Int     @default(0)

  // Linked schedule (optional)
  scheduleId String?
  schedule   Schedule? @relation(fields: [scheduleId], references: [id])

  // Relations
  stops             VoyageStop[]
  manifestItems     ManifestItem[]
  cargoBookings     CargoBooking[]
  passengerBookings PassengerBooking[]

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([shipName])
  @@index([status])
}

// ============================================
// VOYAGE STOPS (Multi-stop routes)
// ============================================

model VoyageStop {
  id        String   @id @default(cuid())
  voyageId  String
  voyage    Voyage   @relation(fields: [voyageId], references: [id], onDelete: Cascade)

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  stopOrder     Int          // 1, 2, 3... (order of stops)
  arrivalTime   String?      // "11:00 AM" (null for first stop — it departs)
  departureTime String?      // "12:30 PM" (null for last stop — final destination)

  // What happens at this stop
  activities    String[]     // ["Freight Drop Off", "Freight Pick Up"]
  notes         String?      // "(Dry Freight Only)"

  createdAt DateTime @default(now())

  @@index([voyageId])
  @@unique([voyageId, stopOrder])
}

// ============================================
// MANIFEST
// ============================================

model ManifestItem {
  id       String @id @default(cuid())
  voyageId String
  voyage   Voyage @relation(fields: [voyageId], references: [id], onDelete: Cascade)

  // Can be linked to cargo or passenger booking
  cargoBookingId     String?
  cargoBooking       CargoBooking?     @relation(fields: [cargoBookingId], references: [id])
  passengerBookingId String?
  passengerBooking   PassengerBooking? @relation(fields: [passengerBookingId], references: [id])

  // Item details (denormalized for manifest view)
  invoiceNo    String
  senderName   String
  receiverName String?
  itemDetails  String
  quantity     Int       @default(1)
  amount       Float
  
  status       ManifestItemStatus @default(PENDING)
  loadedAt     DateTime?
  unloadedAt   DateTime?
  
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([voyageId])
  @@index([status])
}

// ============================================
// SCHEDULES
// ============================================

model Schedule {
  id        String   @id @default(cuid())
  date      DateTime
  weekday   String // MON, TUE, etc.
  month     String // January, February, etc.
  shipName  String // "SHIP_A" or "SHIP_B"
  isHoliday Boolean  @default(false)

  // Schedule events
  events ScheduleEvent[]

  // Voyages generated from this schedule
  voyages Voyage[]

  // Launch controls
  launchAt    DateTime?
  isLaunched  Boolean   @default(false)
  isPublished Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([shipName])
  @@unique([date, shipName])
}

model ScheduleEvent {
  id         String   @id @default(cuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  // Journey endpoints (like train route: Borivali → Churchgate)
  fromLocation   String   // Departure location code (e.g., "NAS")
  toLocation     String   // Arrival location code (e.g., "GTC")
  departureTime  String?  // "8:00 AM"
  arrivalTime    String?  // "2:00 PM"
  
  // Legacy field - kept for backward compatibility, will be removed later
  location       String?  // @deprecated - use fromLocation/toLocation instead
  startTime      String?  // @deprecated - use departureTime instead
  endTime        String?  // @deprecated - use arrivalTime instead

  type     String   // "Freight Drop Off", "Freight Pick Up", "Passenger Boarding"
  notes    String?  // "(Dry Freight Only)", "(Include Freezer & Cooler items)"

  // Intermediate stops (like train stops: Kandivali, Andheri, Bandra, Dadar)
  stops    ScheduleEventStop[]

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Intermediate stops within a journey (like train stations between start and end)
model ScheduleEventStop {
  id             String        @id @default(cuid())
  scheduleEventId String
  scheduleEvent   ScheduleEvent @relation(fields: [scheduleEventId], references: [id], onDelete: Cascade)

  location       String        // Location code (e.g., "MHA")
  arrivalTime    String?       // "10:00 AM"
  departureTime  String?       // "10:30 AM"
  activities     String[]      // ["Freight Drop Off", "Freight Pick Up"]
  notes          String?       // "Dry Freight Only"

  stopOrder      Int           @default(0)
  createdAt      DateTime      @default(now())

  @@index([scheduleEventId])
}

// ============================================
// CARGO BOOKING (Updated with all service-specific fields)
// ============================================

model CargoBooking {
  id        String @id @default(cuid())
  invoiceNo String @unique @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  // Voyage assignment
  voyageId String?
  voyage   Voyage? @relation(fields: [voyageId], references: [id])

  // =========================================
  // SERVICE TYPE & COMMON FIELDS
  // =========================================
  service     CargoServiceType
  boxSubType  BoxSubType?        // Only when service = BOX (DRY, FROZEN, COOLER)
  cargoSize   CargoSizeCategory  @default(MEDIUM)
  
  // Cargo flags (can have multiple)
  isFragile   Boolean @default(false)
  isHazardous Boolean @default(false)
  isLive      Boolean @default(false)

  // Common value/price fields
  value       String?  // Declared value
  price       String?  // Shipping price

  // =========================================
  // CONTAINER-SPECIFIC FIELDS
  // =========================================
  containerNo     String?   // Container number (e.g., "134")
  chassisNo       String?   // Chassis number
  temperature     String?   // Temperature setting (e.g., "70°")
  containerSize   String?   // 20FT, 40FT, 40FT_HC, 45FT
  containerType   String?   // DRY, REEFER, OPEN_TOP, FLAT_RACK
  contents        String?   // What's inside the container

  // =========================================
  // PALLET-SPECIFIC FIELDS
  // =========================================
  palletNo    String?   // Pallet number
  reeferNo    String?   // Reefer number
  palletHeight String?  // 4ft, 5ft, 6ft
  palletType  String?   // DRY, FROZEN, REFRIGERATED
  deckNo      String?   // Deck number

  // Legacy fields (keeping for backwards compatibility)
  quantity    Int?
  pallets     Int?
  type        ContainerType @default(DRY)
  size        String?
  height      String?
  boxContains String?

  // =========================================
  // LUGGAGE-SPECIFIC FIELDS
  // =========================================
  material    String?   // Material type (e.g., Leather, Fabric)
  color       String?   // Color of luggage
  luggageType String?   // Type of luggage (e.g., Suitcase, Duffel)

  // =========================================
  // ENVELOPE-SPECIFIC FIELDS
  // =========================================
  envelopeType EnvelopeType?  // SMALL_BOX, ENVELOPE, PARCEL

  // =========================================
  // BUNDLE-SPECIFIC FIELDS
  // =========================================
  bundleMaterial String?   // Material (e.g., Wood, Metal)
  bundleQuantity String?   // Quantity in bundle
  bundleLength   String?   // Length (e.g., "4'")
  bundleSize     String?   // Size (e.g., "1\" x 4\"")
  itemLocation   ItemLocationType?  // PALLET, CONTAINER, DECK
  itemNumber     String?   // Item number reference

  // =========================================
  // OTHER-SPECIFIC FIELDS
  // =========================================
  itemName    String?   // Custom item name/description

  // =========================================
  // DATES & LOCATIONS
  // =========================================
  bookingDate  DateTime
  fromLocation String
  toLocation   String
  voyageNo     String?

  // =========================================
  // CONTACT DETAILS (snapshot at booking time)
  // =========================================
  contactName  String
  contactEmail String
  contactPhone String
  address      String
  idType       String

  // =========================================
  // DEFICIENCY / DAMAGE TRACKING
  // =========================================
  damageFound       DamageType?        // Type of damage found
  damageLocation    DamageLocationEnum? // Where damage is located
  deficiencyComment String?            // Additional notes about damage

  // =========================================
  // ADDITIONAL SERVICES
  // =========================================
  hasTape                Boolean @default(false)
  wrapType               String? // PARTIAL, FULL
  hasTags                Boolean @default(false)
  insuranceAmount       Float?
  additionalServicePrice Float @default(0)

  // =========================================
  // PAYMENT & TOTALS
  // =========================================
  paymentStatus PaymentStatus @default(UNPAID)
  totalAmount   Float         @default(0)
  vatPercent    Float         @default(12)
  vatAmount     Float         @default(0)
  subtotal      Float         @default(0)
  remark        String?

  // =========================================
  // RELATIONS
  // =========================================
  items         CargoItem[]
  images        BookingImage[]
  invoice       Invoice?
  manifestItems ManifestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([service])
  @@index([paymentStatus])
  @@index([bookingDate])
  @@index([userId])
  @@index([voyageId])
  @@index([createdAt])
  @@index([paymentStatus, bookingDate])
  @@index([fromLocation, toLocation])
}

model CargoItem {
  id        String       @id @default(cuid())
  bookingId String
  booking   CargoBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  itemType  String // "DRY BOX(S)", "Container (40ft)", etc.
  category  PriceCategory?
  size      String?
  unitPrice Float
  quantity  Int
  total     Float
  isPaid    Boolean @default(false)

  createdAt DateTime @default(now())
}

// ============================================
// PASSENGER BOOKING
// ============================================

model PassengerLuggage {
  id                  String            @id @default(cuid())
  passengerBookingId  String
  passengerBooking    PassengerBooking  @relation(fields: [passengerBookingId], references: [id], onDelete: Cascade)
  type                String            // CARRY_ON, CHECKED_BAG, OVERSIZED, SPECIAL
  weight              Float             @default(0)
  quantity            Int               @default(1)
  price               Float             @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([passengerBookingId])
}

model PassengerBooking {
  id        String @id @default(cuid())
  invoiceNo String @unique @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  // Voyage assignment
  voyageId String?
  voyage   Voyage? @relation(fields: [voyageId], references: [id])

  // Passenger counts
  infantCount Int @default(0)
  childCount  Int @default(0)
  adultCount  Int @default(0)

  // Contact details
  name    String
  email   String
  contact String

  // Booking details
  bookingDate  DateTime
  fromLocation String
  toLocation   String
  idType       String

  // Payment
  paymentStatus PaymentStatus @default(UNPAID)
  totalAmount   Float         @default(0)
  vatPercent    Float         @default(12)
  vatAmount     Float         @default(0)
  subtotal      Float         @default(0)
  remark        String?

  // Relations
  images        BookingImage[]
  invoice       Invoice?
  manifestItems ManifestItem[]
  luggage       PassengerLuggage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentStatus])
  @@index([bookingDate])
  @@index([userId])
  @@index([voyageId])
  @@index([createdAt])
}

// ============================================
// SHARED: BOOKING IMAGES (Supabase Storage)
// ============================================

model BookingImage {
  id String @id @default(cuid())

  cargoBookingId     String?
  cargoBooking       CargoBooking?     @relation(fields: [cargoBookingId], references: [id], onDelete: Cascade)
  passengerBookingId String?
  passengerBooking   PassengerBooking? @relation(fields: [passengerBookingId], references: [id], onDelete: Cascade)

  imageUrl  String // Supabase Storage URL
  imageType String // "CONTAINER", "USER_DOCUMENT", "DEFICIENCY"
  caption   String?
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([cargoBookingId])
  @@index([passengerBookingId])
}

// ============================================
// EQUIPMENT MANAGEMENT
// ============================================

model Equipment {
  id         String          @id @default(cuid())
  type       EquipmentType
  name       String // "CHASSIS #01", "FORKLIFT #03"
  identifier String? // Serial or tracking number

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  status     EquipmentStatus @default(AVAILABLE)

  // Relations
  assignments EquipmentAssignment[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([locationId])
  @@index([status])
}

model EquipmentAssignment {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  // Who is using it
  assignedToId String
  assignedTo   User   @relation("AssignedTo", fields: [assignedToId], references: [id])

  // Who assigned it
  assignedById String
  assignedBy   User   @relation("AssignedBy", fields: [assignedById], references: [id])

  // Optional voyage/booking reference
  voyageId       String?
  cargoBookingId String?

  // Assignment period
  assignedAt   DateTime  @default(now())
  releasedAt   DateTime?
  expectedReturn DateTime?

  notes String?

  @@index([equipmentId])
  @@index([assignedToId])
  @@index([assignedAt])
}

// ============================================
// VEHICLE WAIT LIST
// ============================================

model Vehicle {
  id             String        @id @default(cuid())
  invoiceNo      String?       @unique
  registrationNo String
  ownerName      String
  ownerEmail     String?
  contactNo      String    @default("")
  vehicleType    String
  fromLocation   String
  toLocation     String
  status         VehicleStatus @default(PENDING)
  paymentStatus  PaymentStatus @default(UNPAID)
  totalAmount    Float         @default(0)
  paidAt         DateTime?
  paymentMode    String? // Cash, Online, Credit Card, Debit Card
  bookingDate    DateTime

  // Optional voyage assignment
  voyageId String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([bookingDate])
  @@index([registrationNo])
}

// ============================================
// INVOICES & PAYMENTS
// ============================================

model Invoice {
  id        String @id @default(cuid())
  invoiceNo String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Linked booking (one or the other)
  cargoBookingId     String?           @unique
  cargoBooking       CargoBooking?     @relation(fields: [cargoBookingId], references: [id])
  passengerBookingId String?           @unique
  passengerBooking   PassengerBooking? @relation(fields: [passengerBookingId], references: [id])

  subtotal      Float
  vatPercent    Float         @default(12)
  vatAmount     Float
  totalAmount   Float
  paidAmount    Float         @default(0)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMode   String? // Cash, Online, Credit Card, Debit Card
  paidAt        DateTime?

  // Reminder tracking
  reminderFrequency ReminderFrequency?
  lastReminderSent  DateTime?
  reminderCount     Int @default(0)

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([paymentStatus])
  @@index([userId])
  @@index([dueDate])
  @@index([createdAt])
  @@index([paidAt])
}

// ============================================
// INCIDENT REPORTS
// ============================================

model IncidentReport {
  id String @id @default(cuid())

  reportedById String
  reportedBy   User   @relation(fields: [reportedById], references: [id])

  // Incident type
  incidentType String // "Container Damaged", "Cargo Damaged", "Other"
  title        String
  description  String
  
  // Location and reference
  location     String
  invoiceNo    String?
  
  // Details
  date         DateTime @default(now())
  time         String?
  
  // Insurance
  insuranceTaken Boolean @default(false)
  
  // Shipment details
  shipmentDetails String?
  
  severity     IncidentSeverity @default(MEDIUM)
  status       IncidentStatus   @default(OPEN)
  images       String[] // Supabase Storage URLs

  resolvedAt   DateTime?
  resolvedBy   String?
  resolution   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([incidentType])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  message String
  type    String // "booking", "payment", "system", "schedule", "reminder"
  isRead  Boolean @default(false)

  // Optional reference
  referenceType String? // "invoice", "booking", "voyage"
  referenceId   String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([type])
}

// ============================================
// PAYMENT REMINDERS (Automated)
// ============================================

model PaymentReminder {
  id        String @id @default(cuid())
  invoiceId String
  
  sentAt    DateTime @default(now())
  channel   String // "sms", "email", "in_app"
  status    String // "sent", "failed", "delivered"
  
  @@index([invoiceId])
  @@index([sentAt])
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action    String // "LOGIN", "LOGOUT", "CREATE_BOOKING", "UPDATE_PRICE", etc.
  entity    String // "user", "cargo_booking", "price", etc.
  entityId  String?
  metadata  Json? // Additional context
  oldValue  Json? // Previous state for updates
  newValue  Json? // New state for updates

  ipAddress String?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string") // "string", "number", "boolean", "json"
  
  description String?
  
  updatedAt DateTime @updatedAt
}
